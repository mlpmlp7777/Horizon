<Window x:Class="Horizon.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:Horizon.App.ViewModels"
        xmlns:conv="clr-namespace:Horizon.App.Converters"
        mc:Ignorable="d"
        Title="Horizon"
        Width="360"
        Height="900"
        FontFamily="Microsoft YaHei UI"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        Loaded="MainWindow_OnLoaded"
        Closed="MainWindow_OnClosed"
        Deactivated="MainWindow_OnDeactivated"
        LocationChanged="MainWindow_OnLocationOrSizeChanged"
        SizeChanged="MainWindow_OnLocationOrSizeChanged"
        PreviewKeyDown="MainWindow_OnPreviewKeyDown">
    <Window.Resources>
        <SolidColorBrush x:Key="OrbitPanelBrush" Color="#F7F9FD" />
        <SolidColorBrush x:Key="OrbitHeaderBrush" Color="#DCE9FF" />
        <SolidColorBrush x:Key="OrbitPrimaryBrush" Color="#2D68FF" />
        <SolidColorBrush x:Key="OrbitAccentInkBrush" Color="#2458D4" />
        <SolidColorBrush x:Key="OrbitInkBrush" Color="#14213D" />
        <SolidColorBrush x:Key="OrbitMutedBrush" Color="#526686" />
        <SolidColorBrush x:Key="OrbitSelectedBrush" Color="#DCE7FF" />
        <SolidColorBrush x:Key="OrbitMotifBrush" Color="#B8CEFF" />
        <SolidColorBrush x:Key="OrbitShellBorderBrush" Color="#B8C8E1" />
        <SolidColorBrush x:Key="OrbitCollapsedCardBrush" Color="#EAF0F9" />
        <SolidColorBrush x:Key="OrbitExpandedCardBrush" Color="#FFFFFF" />
        <SolidColorBrush x:Key="OrbitExpandedBorderBrush" Color="#9DB9FF" />
        <SolidColorBrush x:Key="OrbitTaskBrush" Color="#EEF3FF" />
        <SolidColorBrush x:Key="OrbitTrackBrush" Color="#D4DEED" />
        <SolidColorBrush x:Key="OrbitSignalBrush" Color="#D6FF58" />
        <SolidColorBrush x:Key="OrbitControlBrush" Color="#F3F6FC" />
        <SolidColorBrush x:Key="OrbitControlBorderBrush" Color="#D6E0F0" />
        <SolidColorBrush x:Key="OrbitCardBorderBrush" Color="#D9E4F5" />
        <SolidColorBrush x:Key="OrbitStatusBrush" Color="#EDF2FB" />
        <SolidColorBrush x:Key="OrbitStatusInkBrush" Color="#466086" />
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <conv:EnumDisplayConverter x:Key="EnumDisplayConverter" />

        <Style x:Key="OrbitScrollPageButtonStyle" TargetType="RepeatButton">
            <Setter Property="Focusable" Value="False" />
            <Setter Property="IsTabStop" Value="False" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RepeatButton">
                        <Border Background="Transparent" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="OrbitScrollThumbStyle" TargetType="Thumb">
            <Setter Property="Background" Value="{StaticResource OrbitPrimaryBrush}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Border Background="{TemplateBinding Background}"
                                Margin="{TemplateBinding BorderThickness}"
                                CornerRadius="4" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <ControlTemplate x:Key="OrbitVerticalScrollBarTemplate" TargetType="ScrollBar">
            <Grid Width="12" Background="Transparent">
                <Border x:Name="TrackChrome"
                        Width="10"
                        HorizontalAlignment="Center"
                        Background="Transparent"
                        CornerRadius="5" />
                <Track x:Name="PART_Track"
                       Minimum="{TemplateBinding Minimum}"
                       Maximum="{TemplateBinding Maximum}"
                       Value="{Binding Value, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                       ViewportSize="{TemplateBinding ViewportSize}"
                       IsDirectionReversed="True"
                       Orientation="Vertical">
                    <Track.DecreaseRepeatButton>
                        <RepeatButton Command="{x:Static ScrollBar.PageUpCommand}"
                                      Style="{StaticResource OrbitScrollPageButtonStyle}" />
                    </Track.DecreaseRepeatButton>
                    <Track.Thumb>
                        <Thumb x:Name="ScrollThumb"
                               Width="12"
                               MinHeight="30"
                               BorderThickness="3,0"
                               HorizontalAlignment="Center"
                               Style="{StaticResource OrbitScrollThumbStyle}" />
                    </Track.Thumb>
                    <Track.IncreaseRepeatButton>
                        <RepeatButton Command="{x:Static ScrollBar.PageDownCommand}"
                                      Style="{StaticResource OrbitScrollPageButtonStyle}" />
                    </Track.IncreaseRepeatButton>
                </Track>
            </Grid>
            <ControlTemplate.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter TargetName="TrackChrome"
                            Property="Background"
                            Value="{StaticResource OrbitCollapsedCardBrush}" />
                    <Setter TargetName="ScrollThumb" Property="BorderThickness" Value="2,0" />
                </Trigger>
                <Trigger SourceName="ScrollThumb" Property="IsDragging" Value="True">
                    <Setter TargetName="ScrollThumb"
                            Property="Background"
                            Value="{StaticResource OrbitAccentInkBrush}" />
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter TargetName="ScrollThumb" Property="Opacity" Value="0.4" />
                </Trigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>

        <ControlTemplate x:Key="OrbitHorizontalScrollBarTemplate" TargetType="ScrollBar">
            <Grid Height="12" Background="Transparent">
                <Border x:Name="TrackChrome"
                        Height="10"
                        VerticalAlignment="Center"
                        Background="Transparent"
                        CornerRadius="5" />
                <Track x:Name="PART_Track"
                       Minimum="{TemplateBinding Minimum}"
                       Maximum="{TemplateBinding Maximum}"
                       Value="{Binding Value, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                       ViewportSize="{TemplateBinding ViewportSize}"
                       IsDirectionReversed="False"
                       Orientation="Horizontal">
                    <Track.DecreaseRepeatButton>
                        <RepeatButton Command="{x:Static ScrollBar.PageLeftCommand}"
                                      Style="{StaticResource OrbitScrollPageButtonStyle}" />
                    </Track.DecreaseRepeatButton>
                    <Track.Thumb>
                        <Thumb x:Name="ScrollThumb"
                               Height="12"
                               MinWidth="30"
                               BorderThickness="0,3"
                               VerticalAlignment="Center"
                               Style="{StaticResource OrbitScrollThumbStyle}" />
                    </Track.Thumb>
                    <Track.IncreaseRepeatButton>
                        <RepeatButton Command="{x:Static ScrollBar.PageRightCommand}"
                                      Style="{StaticResource OrbitScrollPageButtonStyle}" />
                    </Track.IncreaseRepeatButton>
                </Track>
            </Grid>
            <ControlTemplate.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter TargetName="TrackChrome"
                            Property="Background"
                            Value="{StaticResource OrbitCollapsedCardBrush}" />
                    <Setter TargetName="ScrollThumb" Property="BorderThickness" Value="0,2" />
                </Trigger>
                <Trigger SourceName="ScrollThumb" Property="IsDragging" Value="True">
                    <Setter TargetName="ScrollThumb"
                            Property="Background"
                            Value="{StaticResource OrbitAccentInkBrush}" />
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter TargetName="ScrollThumb" Property="Opacity" Value="0.4" />
                </Trigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>

        <Style TargetType="ScrollBar">
            <Setter Property="Width" Value="12" />
            <Setter Property="MinWidth" Value="12" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{StaticResource OrbitPrimaryBrush}" />
            <Setter Property="Template" Value="{StaticResource OrbitVerticalScrollBarTemplate}" />
            <Style.Triggers>
                <Trigger Property="Orientation" Value="Horizontal">
                    <Setter Property="Width" Value="Auto" />
                    <Setter Property="MinWidth" Value="0" />
                    <Setter Property="Height" Value="12" />
                    <Setter Property="MinHeight" Value="12" />
                    <Setter Property="Template" Value="{StaticResource OrbitHorizontalScrollBarTemplate}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="QuickAddContextMenuStyle" TargetType="ContextMenu">
            <Setter Property="Background" Value="{StaticResource OrbitExpandedCardBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource OrbitShellBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="HasDropShadow" Value="False" />
            <Setter Property="ItemsPanel">
                <Setter.Value>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal" />
                    </ItemsPanelTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ContextMenu">
                        <Border Padding="8"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="18">
                            <ItemsPresenter />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="QuickAddMenuItemStyle" TargetType="MenuItem">
            <Setter Property="Width" Value="104" />
            <Setter Property="Height" Value="76" />
            <Setter Property="Margin" Value="3" />
            <Setter Property="Background" Value="{StaticResource OrbitTaskBrush}" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="{StaticResource OrbitInkBrush}" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="MenuItem">
                        <Border x:Name="MenuCard"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="13">
                            <StackPanel HorizontalAlignment="Center"
                                        VerticalAlignment="Center">
                                <Border x:Name="IconCard"
                                        Width="30"
                                        Height="30"
                                        HorizontalAlignment="Center"
                                        Background="{StaticResource OrbitHeaderBrush}"
                                        CornerRadius="11">
                                    <TextBlock x:Name="IconText"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               Text="{TemplateBinding Tag}"
                                               FontSize="13"
                                               FontWeight="Bold"
                                               Foreground="{StaticResource OrbitPrimaryBrush}" />
                                </Border>
                                <TextBlock x:Name="MenuLabel"
                                           Margin="4,7,4,0"
                                           HorizontalAlignment="Center"
                                           Text="{TemplateBinding Header}"
                                           TextAlignment="Center"
                                           FontSize="10.5"
                                           FontWeight="SemiBold"
                                           Foreground="{TemplateBinding Foreground}" />
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="MenuCard" Property="Background" Value="{StaticResource OrbitHeaderBrush}" />
                                <Setter TargetName="MenuCard" Property="BorderBrush" Value="{StaticResource OrbitExpandedBorderBrush}" />
                            </Trigger>
                            <Trigger Property="IsMouseCaptureWithin" Value="True">
                                <Setter TargetName="MenuCard" Property="Background" Value="{StaticResource OrbitPrimaryBrush}" />
                                <Setter TargetName="MenuCard" Property="BorderBrush" Value="{StaticResource OrbitPrimaryBrush}" />
                                <Setter TargetName="MenuLabel" Property="Foreground" Value="White" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="MenuCard" Property="Opacity" Value="0.4" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource OrbitInkBrush}" />
        </Style>

        <Style TargetType="Button">
            <Setter Property="Foreground" Value="{StaticResource OrbitInkBrush}" />
            <Setter Property="Background" Value="{StaticResource OrbitControlBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource OrbitControlBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="10,6" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontSize" Value="11.5" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonChrome"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12"
                                RenderTransformOrigin="0.5,0.5">
                            <Border.RenderTransform>
                                <ScaleTransform ScaleX="1" ScaleY="1" />
                            </Border.RenderTransform>
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonChrome" Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="1.01" ScaleY="1.01" />
                                    </Setter.Value>
                                </Setter>
                                <Setter TargetName="ButtonChrome" Property="BorderBrush" Value="{StaticResource OrbitShellBorderBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonChrome" Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="0.98" ScaleY="0.98" />
                                    </Setter.Value>
                                </Setter>
                                <Setter TargetName="ButtonChrome" Property="BorderBrush" Value="{StaticResource OrbitAccentInkBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ButtonChrome" Property="Opacity" Value="0.4" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ActionButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="{StaticResource OrbitControlBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource OrbitControlBorderBrush}" />
            <Setter Property="Foreground" Value="{StaticResource OrbitInkBrush}" />
        </Style>

        <Style x:Key="PinToggleButtonStyle" TargetType="ToggleButton">
            <Setter Property="Background" Value="{StaticResource OrbitControlBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource OrbitControlBorderBrush}" />
            <Setter Property="Foreground" Value="{StaticResource OrbitMutedBrush}" />
            <Setter Property="Padding" Value="10,6" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="ToggleChrome"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="12">
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter Property="Background" Value="{StaticResource OrbitSelectedBrush}" />
                                <Setter Property="BorderBrush" Value="{StaticResource OrbitExpandedBorderBrush}" />
                                <Setter Property="Foreground" Value="{StaticResource OrbitAccentInkBrush}" />
                                <Setter Property="FontWeight" Value="SemiBold" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ToggleChrome" Property="BorderBrush" Value="{StaticResource OrbitShellBorderBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryActionButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="{StaticResource OrbitPrimaryBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource OrbitPrimaryBrush}" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Padding" Value="12,7" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style x:Key="MiniButtonStyle" TargetType="Button" BasedOn="{StaticResource ActionButtonStyle}">
            <Setter Property="Padding" Value="8,4" />
            <Setter Property="FontSize" Value="10.5" />
        </Style>

        <Style x:Key="HistoryWeekButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource OrbitExpandedCardBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource OrbitCardBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="12" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="HistoryCardChrome"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12">
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              HorizontalAlignment="Stretch"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="HistoryCardChrome" Property="Background" Value="{StaticResource OrbitTaskBrush}" />
                                <Setter TargetName="HistoryCardChrome" Property="BorderBrush" Value="{StaticResource OrbitExpandedBorderBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="HistoryCardChrome" Property="BorderBrush" Value="{StaticResource OrbitAccentInkBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="LinkButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Foreground" Value="{StaticResource OrbitPrimaryBrush}" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style x:Key="SegmentRadioButtonStyle" TargetType="RadioButton">
            <Setter Property="Foreground" Value="{StaticResource OrbitMutedBrush}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="FontSize" Value="10" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Chip"
                                Margin="2"
                                Padding="8,5"
                                Background="Transparent"
                                CornerRadius="10">
                            <TextBlock Text="{TemplateBinding Content}"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       FontSize="{TemplateBinding FontSize}"
                                       Foreground="{TemplateBinding Foreground}"
                                       FontWeight="Medium" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Chip" Property="Background" Value="{StaticResource OrbitExpandedCardBrush}" />
                                <Setter Property="Foreground" Value="{StaticResource OrbitAccentInkBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Padding" Value="7,4" />
            <Setter Property="Background" Value="{StaticResource OrbitExpandedCardBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource OrbitControlBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="{StaticResource OrbitInkBrush}" />
        </Style>

        <Style TargetType="DatePicker">
            <Setter Property="Background" Value="{StaticResource OrbitExpandedCardBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource OrbitControlBorderBrush}" />
            <Setter Property="Foreground" Value="{StaticResource OrbitInkBrush}" />
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Padding" Value="9,7" />
            <Setter Property="Background" Value="{StaticResource OrbitExpandedCardBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource OrbitControlBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="{StaticResource OrbitInkBrush}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ProgressBar">
            <Setter Property="Height" Value="6" />
            <Setter Property="Maximum" Value="100" />
            <Setter Property="Background" Value="{StaticResource OrbitTrackBrush}" />
            <Setter Property="Foreground" Value="{StaticResource OrbitPrimaryBrush}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ProgressBar">
                        <Grid x:Name="PART_Track">
                            <Border CornerRadius="3"
                                    Background="{TemplateBinding Background}" />
                            <Border x:Name="PART_Indicator"
                                    HorizontalAlignment="Left"
                                    Background="{TemplateBinding Foreground}"
                                    CornerRadius="3" />
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PanelCardStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource OrbitExpandedCardBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource OrbitCardBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="18" />
        </Style>

        <Style x:Key="ProjectCardStyle" TargetType="Border">
            <Setter Property="Margin" Value="0,0,0,8" />
            <Setter Property="Padding" Value="10" />
            <Setter Property="Background" Value="{StaticResource OrbitCollapsedCardBrush}" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="2" />
            <Setter Property="CornerRadius" Value="18" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsExpanded}" Value="True">
                    <Setter Property="Background" Value="{StaticResource OrbitExpandedCardBrush}" />
                    <Setter Property="BorderBrush" Value="{StaticResource OrbitExpandedBorderBrush}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ProjectSummaryButtonStyle" TargetType="Button">
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="14">
                            <ContentPresenter HorizontalAlignment="Stretch" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <DataTemplate x:Key="ProjectSummaryContentTemplate" DataType="{x:Type vm:ProjectSectionViewModel}">
            <StackPanel>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Border Width="22" Height="22" CornerRadius="11"
                            VerticalAlignment="Center"
                            Background="{StaticResource OrbitHeaderBrush}"
                            Visibility="{Binding IsCollapsible, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <TextBlock Text="{Binding ExpansionGlyph}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   FontSize="11"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource OrbitPrimaryBrush}" />
                    </Border>

                    <StackPanel Grid.Column="1" Margin="9,0,8,0">
                        <TextBlock Text="{Binding ProjectName}"
                                   ToolTip="{Binding ProjectName}"
                                   FontSize="12.5"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource OrbitInkBrush}"
                                   TextTrimming="CharacterEllipsis" />
                        <TextBlock Margin="0,3,0,0"
                                   Text="{Binding ProjectMeta}"
                                   ToolTip="{Binding ProjectMeta}"
                                   FontSize="9.5"
                                   Foreground="{StaticResource OrbitMutedBrush}"
                                   TextTrimming="CharacterEllipsis" />
                    </StackPanel>

                    <Border Grid.Column="2" Padding="7,4" CornerRadius="10"
                            VerticalAlignment="Center"
                            Background="{StaticResource OrbitSelectedBrush}">
                        <TextBlock Text="{Binding StatusText}"
                                   FontSize="9"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource OrbitAccentInkBrush}" />
                    </Border>
                </Grid>

                <ProgressBar Margin="31,9,0,0"
                             Height="5"
                             Value="{Binding Progress, Mode=OneWay}"
                             Foreground="{StaticResource OrbitPrimaryBrush}"
                             Background="{StaticResource OrbitTrackBrush}" />
            </StackPanel>
        </DataTemplate>

        <DataTemplate x:Key="ProjectSummaryInteractiveTemplate" DataType="{x:Type vm:ProjectSectionViewModel}">
            <Button HorizontalAlignment="Stretch"
                    AutomationProperties.HelpText="{Binding Text, ElementName=ProjectSummaryAutomationHelp}"
                    Click="ProjectSummaryButton_OnClick">
                <Button.Style>
                    <Style TargetType="Button" BasedOn="{StaticResource ProjectSummaryButtonStyle}">
                        <Setter Property="AutomationProperties.Name"
                                Value="{Binding ProjectName, StringFormat=项目 {0}，已收起，按 Enter 展开}" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsExpanded}" Value="True">
                                <Setter Property="AutomationProperties.Name"
                                        Value="{Binding ProjectName, StringFormat=项目 {0}，已展开，按 Enter 收起}" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
                <Grid>
                    <TextBlock x:Name="ProjectSummaryAutomationHelp" Visibility="Collapsed">
                        <Run Text="{Binding ProjectMeta}" /><Run Text="；项目状态：" /><Run Text="{Binding StatusText}" />
                    </TextBlock>
                    <ContentControl Content="{Binding}"
                                    HorizontalContentAlignment="Stretch"
                                    ContentTemplate="{StaticResource ProjectSummaryContentTemplate}" />
                </Grid>
            </Button>
        </DataTemplate>

        <DataTemplate x:Key="ProjectSummaryReadOnlyTemplate" DataType="{x:Type vm:ProjectSectionViewModel}">
            <ContentControl Content="{Binding}"
                            HorizontalContentAlignment="Stretch"
                            ContentTemplate="{StaticResource ProjectSummaryContentTemplate}" />
        </DataTemplate>

        <Style x:Key="ProjectSummaryPresenterStyle" TargetType="ContentControl">
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="ContentTemplate" Value="{StaticResource ProjectSummaryReadOnlyTemplate}" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsCollapsible}" Value="True">
                    <Setter Property="ContentTemplate" Value="{StaticResource ProjectSummaryInteractiveTemplate}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <DataTemplate x:Key="WeeklyProjectSectionTemplate" DataType="{x:Type vm:ProjectSectionViewModel}">
            <Border Style="{StaticResource ProjectCardStyle}">
                <StackPanel>
                    <ContentControl Content="{Binding}"
                                    Style="{StaticResource ProjectSummaryPresenterStyle}" />

                    <StackPanel Margin="0,10,0,0"
                                Visibility="{Binding IsExpanded, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <ItemsControl ItemsSource="{Binding WeeklyTasks}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,0,0,8"
                                        Padding="10"
                                        Background="{StaticResource OrbitTaskBrush}"
                                        BorderBrush="{StaticResource OrbitCardBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="14">
                                    <StackPanel>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>

                                            <StackPanel Grid.Column="0" Margin="0,0,10,0">
                                                <TextBlock Text="{Binding Title}"
                                                           FontSize="12"
                                                           FontWeight="SemiBold"
                                                           TextWrapping="Wrap"
                                                           Foreground="{StaticResource OrbitInkBrush}" />
                                            </StackPanel>

                                            <WrapPanel Grid.Column="1" HorizontalAlignment="Right">
                                                <Button Style="{StaticResource MiniButtonStyle}"
                                                        Content="编辑"
                                                        Tag="{Binding Id}"
                                                        Click="EditWeeklyTaskButton_OnClick" />
                                                <Button Margin="4,0,0,0"
                                                        Style="{StaticResource MiniButtonStyle}"
                                                        Content="{Binding ArchiveActionText}"
                                                        Tag="{Binding Id}"
                                                        Click="ArchiveWeeklyTaskButton_OnClick" />
                                            </WrapPanel>
                                        </Grid>

                                        <Border Margin="0,8,0,0"
                                                Padding="9,7"
                                                Background="{StaticResource OrbitExpandedCardBrush}"
                                                BorderBrush="{StaticResource OrbitCardBorderBrush}"
                                                BorderThickness="1"
                                                CornerRadius="12"
                                                Visibility="{Binding HasNotesPreview, Converter={StaticResource BooleanToVisibilityConverter}}">
                                            <TextBlock Text="{Binding NotesPreview}"
                                                       FontSize="10"
                                                       Foreground="{StaticResource OrbitStatusInkBrush}"
                                                       TextWrapping="Wrap" />
                                        </Border>

                                        <Grid Margin="0,8,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock VerticalAlignment="Center"
                                                       Margin="0,0,8,0"
                                                       Text="{Binding ProgressText, StringFormat=进度 {0}}"
                                                       FontSize="10"
                                                       Foreground="{StaticResource OrbitMutedBrush}" />
                                            <ProgressBar Grid.Column="1"
                                                         VerticalAlignment="Center"
                                                         Foreground="{StaticResource OrbitPrimaryBrush}"
                                                         Value="{Binding ProgressValue, Mode=OneWay}" />
                                        </Grid>

                                        <Border Margin="0,8,0,0"
                                                Padding="2"
                                                Background="{StaticResource OrbitTrackBrush}"
                                                BorderBrush="{StaticResource OrbitControlBorderBrush}"
                                                BorderThickness="1"
                                                CornerRadius="10">
                                            <UniformGrid Columns="3">
                                                <RadioButton Style="{StaticResource SegmentRadioButtonStyle}"
                                                             GroupName="{Binding GroupName}"
                                                             Content="未开始"
                                                             Tag="{Binding Id}"
                                                             IsChecked="{Binding IsTodo, Mode=OneWay}"
                                                             Checked="WeeklyTodoButton_OnChecked" />
                                                <RadioButton Style="{StaticResource SegmentRadioButtonStyle}"
                                                             GroupName="{Binding GroupName}"
                                                             Content="进行中"
                                                             Tag="{Binding Id}"
                                                             IsChecked="{Binding IsInProgress, Mode=OneWay}"
                                                             Checked="WeeklyInProgressButton_OnChecked" />
                                                <RadioButton Style="{StaticResource SegmentRadioButtonStyle}"
                                                             GroupName="{Binding GroupName}"
                                                             Content="已完成"
                                                             Tag="{Binding Id}"
                                                             IsChecked="{Binding IsDone, Mode=OneWay}"
                                                             Checked="WeeklyDoneButton_OnChecked" />
                                            </UniformGrid>
                                        </Border>

                                        <Border Margin="0,8,0,0"
                                                Padding="0,8,0,0"
                                                BorderBrush="{StaticResource OrbitCardBorderBrush}"
                                                BorderThickness="0,1,0,0">
                                            <StackPanel>
                                                <Grid Visibility="{Binding HasAnnotations, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Margin="0,0,8,0"
                                                               Text="{Binding LatestAnnotationText}"
                                                               FontSize="10"
                                                               Foreground="{StaticResource OrbitMutedBrush}"
                                                               TextWrapping="NoWrap"
                                                               TextTrimming="CharacterEllipsis" />
                                                    <TextBlock Grid.Column="1"
                                                               Text="{Binding LatestAnnotationTimeText}"
                                                               FontSize="9"
                                                               Foreground="{StaticResource OrbitMutedBrush}" />
                                                </Grid>
                                                <Button Margin="0,5,0,0"
                                                        HorizontalAlignment="Right"
                                                        Style="{StaticResource LinkButtonStyle}"
                                                        Content="{Binding AnnotationActionText}"
                                                        FontSize="9.5"
                                                        Tag="{Binding Id}"
                                                        Click="OpenWeeklyAnnotationsButton_OnClick" />
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                        </ItemsControl>

                    <Button Margin="0,2,0,0"
                            HorizontalAlignment="Left"
                            Style="{StaticResource LinkButtonStyle}"
                            Content="+ 添加本周任务"
                            Visibility="{Binding ShowAddTaskAction, Converter={StaticResource BooleanToVisibilityConverter}}"
                            Tag="{Binding ProjectId}"
                            Click="AddWeeklyTaskForProjectButton_OnClick" />
                    </StackPanel>
                </StackPanel>
            </Border>
        </DataTemplate>

        <DataTemplate x:Key="LongTermProjectSectionTemplate" DataType="{x:Type vm:ProjectSectionViewModel}">
            <Border Style="{StaticResource ProjectCardStyle}">
                <StackPanel>
                    <ContentControl Content="{Binding}"
                                    Style="{StaticResource ProjectSummaryPresenterStyle}" />

                    <StackPanel Margin="0,10,0,0"
                                Visibility="{Binding IsExpanded, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <ItemsControl ItemsSource="{Binding LongTermTasks}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,0,0,8"
                                        Padding="10"
                                        Background="{StaticResource OrbitTaskBrush}"
                                        BorderBrush="{StaticResource OrbitCardBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="14">
                                    <StackPanel>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>

                                            <StackPanel Grid.Column="0" Margin="0,0,10,0">
                                                <TextBlock Text="{Binding Title}"
                                                           FontSize="12"
                                                           FontWeight="SemiBold"
                                                           TextWrapping="Wrap"
                                                           Foreground="{StaticResource OrbitInkBrush}" />
                                                <TextBlock Margin="0,5,0,0"
                                                           Text="{Binding MetaText}"
                                                           FontSize="10"
                                                           Foreground="{StaticResource OrbitMutedBrush}"
                                                           Visibility="{Binding HasMetaText, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                            </StackPanel>

                                            <WrapPanel Grid.Column="1" HorizontalAlignment="Right">
                                                <Button Style="{StaticResource MiniButtonStyle}"
                                                        Content="编辑"
                                                        Tag="{Binding Id}"
                                                        Click="EditLongTermTaskButton_OnClick" />
                                                <Button Margin="4,0,0,0"
                                                        Style="{StaticResource MiniButtonStyle}"
                                                        Content="{Binding ArchiveActionText}"
                                                        Tag="{Binding Id}"
                                                        Click="ArchiveLongTermTaskButton_OnClick" />
                                            </WrapPanel>
                                        </Grid>

                                        <Border Margin="0,8,0,0"
                                                Padding="9,7"
                                                Background="{StaticResource OrbitExpandedCardBrush}"
                                                BorderBrush="{StaticResource OrbitCardBorderBrush}"
                                                BorderThickness="1"
                                                CornerRadius="12"
                                                Visibility="{Binding HasNotesPreview, Converter={StaticResource BooleanToVisibilityConverter}}">
                                            <TextBlock Text="{Binding NotesPreview}"
                                                       FontSize="10"
                                                       Foreground="{StaticResource OrbitStatusInkBrush}"
                                                       TextWrapping="Wrap" />
                                        </Border>

                                        <Grid Margin="0,8,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock VerticalAlignment="Center"
                                                       Margin="0,0,8,0"
                                                       Text="{Binding ProgressText, StringFormat=进度 {0}}"
                                                       FontSize="10"
                                                       Foreground="{StaticResource OrbitMutedBrush}" />
                                            <ProgressBar Grid.Column="1"
                                                         VerticalAlignment="Center"
                                                         Foreground="{StaticResource OrbitPrimaryBrush}"
                                                         Value="{Binding ProgressValue, Mode=OneWay}" />
                                        </Grid>

                                        <Border Margin="0,8,0,0"
                                                Padding="2"
                                                Background="{StaticResource OrbitTrackBrush}"
                                                BorderBrush="{StaticResource OrbitControlBorderBrush}"
                                                BorderThickness="1"
                                                CornerRadius="10">
                                            <UniformGrid Columns="3">
                                                <RadioButton Style="{StaticResource SegmentRadioButtonStyle}"
                                                             GroupName="{Binding GroupName}"
                                                             Content="未开始"
                                                             Tag="{Binding Id}"
                                                             IsChecked="{Binding IsPlanned, Mode=OneWay}"
                                                             Checked="LongTermPlannedButton_OnChecked" />
                                                <RadioButton Style="{StaticResource SegmentRadioButtonStyle}"
                                                             GroupName="{Binding GroupName}"
                                                             Content="进行中"
                                                             Tag="{Binding Id}"
                                                             IsChecked="{Binding IsActive, Mode=OneWay}"
                                                             Checked="LongTermActiveButton_OnChecked" />
                                                <RadioButton Style="{StaticResource SegmentRadioButtonStyle}"
                                                             GroupName="{Binding GroupName}"
                                                             Content="已完成"
                                                             Tag="{Binding Id}"
                                                             IsChecked="{Binding IsCompleted, Mode=OneWay}"
                                                             Checked="LongTermCompletedButton_OnChecked" />
                                            </UniformGrid>
                                        </Border>

                                        <Border Margin="0,8,0,0"
                                                Padding="0,8,0,0"
                                                BorderBrush="{StaticResource OrbitCardBorderBrush}"
                                                BorderThickness="0,1,0,0">
                                            <StackPanel>
                                                <Grid Visibility="{Binding HasAnnotations, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Margin="0,0,8,0"
                                                               Text="{Binding LatestAnnotationText}"
                                                               FontSize="10"
                                                               Foreground="{StaticResource OrbitMutedBrush}"
                                                               TextWrapping="NoWrap"
                                                               TextTrimming="CharacterEllipsis" />
                                                    <TextBlock Grid.Column="1"
                                                               Text="{Binding LatestAnnotationTimeText}"
                                                               FontSize="9"
                                                               Foreground="{StaticResource OrbitMutedBrush}" />
                                                </Grid>
                                                <Button Margin="0,5,0,0"
                                                        HorizontalAlignment="Right"
                                                        Style="{StaticResource LinkButtonStyle}"
                                                        Content="{Binding AnnotationActionText}"
                                                        FontSize="9.5"
                                                        Tag="{Binding Id}"
                                                        Click="OpenLongTermAnnotationsButton_OnClick" />
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                        </ItemsControl>

                    <Button Margin="0,2,0,0"
                            HorizontalAlignment="Left"
                            Style="{StaticResource LinkButtonStyle}"
                            Content="+ 添加长期任务"
                            Visibility="{Binding ShowAddTaskAction, Converter={StaticResource BooleanToVisibilityConverter}}"
                            Tag="{Binding ProjectId}"
                            Click="AddLongTermTaskForProjectButton_OnClick" />
                    </StackPanel>
                </StackPanel>
            </Border>
        </DataTemplate>
    </Window.Resources>

    <Grid>
        <Border x:Name="ExpandedPanelShell"
                Margin="6"
                Background="{StaticResource OrbitPanelBrush}"
                BorderBrush="{StaticResource OrbitShellBorderBrush}"
                BorderThickness="1"
                CornerRadius="30"
                ClipToBounds="True">
            <Grid Margin="18,22,16,16">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Border Grid.RowSpan="4"
                        Height="112"
                        Margin="-18,-22,-16,0"
                        VerticalAlignment="Top"
                        Background="{StaticResource OrbitHeaderBrush}"
                        CornerRadius="29,29,0,0"
                        IsHitTestVisible="False" />
                <Ellipse Grid.RowSpan="4"
                         Width="118"
                         Height="118"
                         Margin="0,-68,-52,0"
                         HorizontalAlignment="Right"
                         VerticalAlignment="Top"
                         Stroke="{StaticResource OrbitMotifBrush}"
                         StrokeThickness="22"
                         Opacity="0.75"
                         IsHitTestVisible="False" />
                <Ellipse Grid.RowSpan="4"
                         Width="8"
                         Height="8"
                         Margin="0,-5,10,0"
                         HorizontalAlignment="Right"
                         VerticalAlignment="Top"
                         Fill="{StaticResource OrbitSignalBrush}"
                         IsHitTestVisible="False" />

                <Grid Grid.Row="0" Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Grid Grid.Column="0" Margin="0,0,10,0" VerticalAlignment="Center">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Image Width="28"
                               Height="28"
                               Margin="0,0,9,0"
                               VerticalAlignment="Center"
                               Source="/Horizon.App;component/Assets/horizon-logo.png"
                               Stretch="Uniform" />
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="Horizon"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource OrbitInkBrush}" />
                            <TextBlock Margin="0,3,0,0"
                                       Text="{Binding HeaderSubtitle}"
                                       FontSize="10"
                                       Foreground="{StaticResource OrbitMutedBrush}" />
                        </StackPanel>
                    </Grid>

                    <ToggleButton Grid.Column="1"
                                  VerticalAlignment="Center"
                                  Style="{StaticResource PinToggleButtonStyle}"
                                  Content="{Binding PinButtonText}"
                                  IsChecked="{Binding IsPinned, Mode=OneWay}"
                                  Click="PinButton_OnClick" />
                </Grid>

                <WrapPanel Grid.Row="1" Margin="0,0,0,10">
                    <Button x:Name="QuickAddButton"
                            Margin="0,0,6,0"
                            Style="{StaticResource PrimaryActionButtonStyle}"
                            Content="新增内容"
                            Click="QuickAddButton_OnClick" />
                    <Button Margin="0,0,6,0"
                            Style="{StaticResource ActionButtonStyle}"
                            Content="设置"
                            Click="SettingsButton_OnClick" />
                    <Button Margin="0,0,6,0"
                            Style="{StaticResource ActionButtonStyle}"
                            Content="{Binding ArchiveToggleText}"
                            Click="ArchiveToggleButton_OnClick" />
                    <Button Style="{StaticResource ActionButtonStyle}"
                            Content="{Binding HistoryToggleText}"
                            Click="HistoryToggleButton_OnClick" />
                </WrapPanel>

                <Border Grid.Row="2"
                        Margin="0,0,0,10"
                        Padding="10,8"
                        Background="{StaticResource OrbitStatusBrush}"
                        BorderBrush="{StaticResource OrbitControlBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="14"
                        Visibility="{Binding HasStatusMessage, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <TextBlock Text="{Binding StatusMessage}"
                               FontSize="10"
                               Foreground="{StaticResource OrbitStatusInkBrush}" />
                </Border>

                <ScrollViewer Grid.Row="3" VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <StackPanel Visibility="{Binding IsCurrentWeeklyView, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock VerticalAlignment="Center"
                                           Text="本周任务"
                                           FontSize="14.5"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource OrbitInkBrush}" />
                                <Button Grid.Column="1"
                                        MinWidth="64"
                                        VerticalAlignment="Center"
                                        Style="{StaticResource MiniButtonStyle}"
                                        Content="{Binding BulkProjectExpansionActionText}"
                                        IsEnabled="{Binding CanBulkToggleProjectExpansion}"
                                        AutomationProperties.HelpText="展开或收起当前页面中的全部项目任务"
                                        Click="BulkProjectExpansionButton_OnClick" />
                            </Grid>
                            <TextBlock Margin="0,4,0,10"
                                       Text="右侧按钮只能贴着屏幕最右边，上下拖动位置，点击后展开面板。"
                                       FontSize="10.5"
                                       Foreground="{StaticResource OrbitMutedBrush}" />

                            <Border Padding="14"
                                    Margin="0,0,0,10"
                                    Style="{StaticResource PanelCardStyle}"
                                    Visibility="{Binding ShowWeeklyEmptyState, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <StackPanel>
                                    <TextBlock Text="本周还没有任务"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource OrbitInkBrush}" />
                                    <TextBlock Margin="0,6,0,12"
                                               Text="本周任务默认就是当前周内容，不再额外设置开始和截止时间。"
                                               FontSize="10.5"
                                               Foreground="{StaticResource OrbitMutedBrush}"
                                               TextWrapping="Wrap" />
                                    <Button HorizontalAlignment="Left"
                                            Style="{StaticResource PrimaryActionButtonStyle}"
                                            Content="新增本周任务"
                                            Click="CreateWeeklyTaskButton_OnClick" />
                                </StackPanel>
                            </Border>

                            <ItemsControl ItemsSource="{Binding WeeklySections}"
                                          ItemTemplate="{StaticResource WeeklyProjectSectionTemplate}" />

                            <TextBlock Margin="0,6,0,0"
                                       Text="长期任务"
                                       FontSize="14.5"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource OrbitInkBrush}" />
                            <TextBlock Margin="0,4,0,10"
                                       Text="长期任务按项目归类，并保留开始时间和结束时间。"
                                       FontSize="10.5"
                                       Foreground="{StaticResource OrbitMutedBrush}" />

                            <Border Padding="14"
                                    Margin="0,0,0,10"
                                    Style="{StaticResource PanelCardStyle}"
                                    Visibility="{Binding ShowLongTermEmptyState, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <StackPanel>
                                    <TextBlock Text="还没有长期任务"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource OrbitInkBrush}" />
                                    <TextBlock Margin="0,6,0,12"
                                               Text="可以先在设置里建好项目，再从下拉里快速选择。"
                                               FontSize="10.5"
                                               Foreground="{StaticResource OrbitMutedBrush}"
                                               TextWrapping="Wrap" />
                                    <Button HorizontalAlignment="Left"
                                            Style="{StaticResource ActionButtonStyle}"
                                            Content="新增长期任务"
                                            Click="CreateLongTermTaskButton_OnClick" />
                                </StackPanel>
                            </Border>

                            <ItemsControl ItemsSource="{Binding LongTermSections}"
                                          ItemTemplate="{StaticResource LongTermProjectSectionTemplate}" />
                        </StackPanel>

                        <StackPanel Visibility="{Binding ShowHistoryView, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <TextBlock Text="历史"
                                       FontSize="14.5"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource OrbitInkBrush}" />
                            <TextBlock Margin="0,4,0,10"
                                       Text="先按周浏览摘要，再进入所选周查看具体任务。"
                                       FontSize="10.5"
                                       Foreground="{StaticResource OrbitMutedBrush}" />

                            <Border Padding="2"
                                    Margin="0,0,0,10"
                                    Background="{StaticResource OrbitTrackBrush}"
                                    CornerRadius="10">
                                <UniformGrid Columns="2">
                                    <RadioButton Style="{StaticResource SegmentRadioButtonStyle}"
                                                 GroupName="history-kind"
                                                 Content="每周任务"
                                                 IsChecked="{Binding IsWeeklyHistoryKind, Mode=OneWay}"
                                                 Checked="SelectWeeklyHistoryButton_OnClick" />
                                    <RadioButton Style="{StaticResource SegmentRadioButtonStyle}"
                                                 GroupName="history-kind"
                                                 Content="长期任务"
                                                 IsChecked="{Binding IsLongTermHistoryKind, Mode=OneWay}"
                                                 Checked="SelectLongTermHistoryButton_OnClick" />
                                </UniformGrid>
                            </Border>

                            <StackPanel Visibility="{Binding ShowHistoryWeekList, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <Border Padding="14"
                                        Margin="0,0,0,10"
                                        Style="{StaticResource PanelCardStyle}"
                                        Visibility="{Binding ShowHistoryEmptyState, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <TextBlock Text="当前类型还没有历史任务。"
                                               FontSize="10.5"
                                               Foreground="{StaticResource OrbitMutedBrush}" />
                                </Border>

                                <ItemsControl ItemsSource="{Binding HistoryWeeks}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Button Margin="0,0,0,9"
                                                    Style="{StaticResource HistoryWeekButtonStyle}"
                                                    Tag="{Binding WeekStartDate}"
                                                    Click="OpenHistoryWeekButton_OnClick">
                                                <StackPanel>
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="Auto" />
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Text="{Binding WeekTitle}"
                                                                   FontSize="12"
                                                                   FontWeight="SemiBold"
                                                                   Foreground="{StaticResource OrbitInkBrush}" />
                                                        <TextBlock Grid.Column="1"
                                                                   Text="›"
                                                                   Foreground="{StaticResource OrbitMutedBrush}" />
                                                    </Grid>
                                                    <TextBlock Margin="0,6,0,0"
                                                               Text="{Binding SummaryText}"
                                                               FontSize="10"
                                                               Foreground="{StaticResource OrbitMutedBrush}" />
                                                    <ProgressBar Margin="0,8,0,0"
                                                                 Foreground="{StaticResource OrbitPrimaryBrush}"
                                                                 Value="{Binding ProgressValue, Mode=OneWay}" />
                                                </StackPanel>
                                            </Button>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>

                            <StackPanel Visibility="{Binding ShowHistoryWeekDetail, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <Button Margin="0,0,0,10"
                                        HorizontalAlignment="Left"
                                        Style="{StaticResource LinkButtonStyle}"
                                        Content="‹ 返回周列表"
                                        Click="BackToHistoryWeeksButton_OnClick" />
                                <TextBlock Text="{Binding SelectedHistoryTitle}"
                                           FontSize="13"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource OrbitInkBrush}" />
                                <TextBlock Margin="0,4,0,10"
                                           Text="{Binding SelectedHistorySummary}"
                                           FontSize="10"
                                           Foreground="{StaticResource OrbitMutedBrush}" />
                                <ItemsControl ItemsSource="{Binding HistoryDetailSections}"
                                              ItemTemplate="{StaticResource WeeklyProjectSectionTemplate}"
                                              Visibility="{Binding IsWeeklyHistoryKind, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                <ItemsControl ItemsSource="{Binding HistoryDetailSections}"
                                              ItemTemplate="{StaticResource LongTermProjectSectionTemplate}"
                                              Visibility="{Binding IsLongTermHistoryKind, Converter={StaticResource BooleanToVisibilityConverter}}" />
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Border>

        <Border x:Name="CollapsedSliverShell"
                Width="6"
                Height="72"
                Background="{StaticResource OrbitPrimaryBrush}"
                CornerRadius="6,0,0,6"
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Visibility="Collapsed"
                MouseEnter="CollapsedSliverShell_OnMouseEnter" />

        <Border x:Name="HoverHandleShell"
                Width="30"
                Height="92"
                Background="{StaticResource OrbitPrimaryBrush}"
                BorderBrush="{StaticResource OrbitAccentInkBrush}"
                BorderThickness="1"
                CornerRadius="14,0,0,14"
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Visibility="Collapsed"
                Cursor="Hand"
                MouseEnter="HoverHandleShell_OnMouseEnter"
                MouseLeave="HoverHandleShell_OnMouseLeave"
                LostMouseCapture="HoverHandleShell_OnLostMouseCapture"
                PreviewMouseLeftButtonDown="HoverHandleShell_OnMouseLeftButtonDown"
                PreviewMouseMove="HoverHandleShell_OnMouseMove"
                PreviewMouseLeftButtonUp="HoverHandleShell_OnMouseLeftButtonUp">
            <Grid Margin="5,9">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Border Width="16"
                        Height="3"
                        CornerRadius="2"
                        HorizontalAlignment="Center"
                        Background="{StaticResource OrbitMotifBrush}" />

                <TextBlock Grid.Row="1"
                           Text="H"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           FontSize="15"
                           FontWeight="Bold"
                           Foreground="White" />

                <TextBlock Grid.Row="2"
                           Text="拖"
                           HorizontalAlignment="Center"
                           FontSize="9"
                           Foreground="{StaticResource OrbitHeaderBrush}" />
            </Grid>
        </Border>

        <Grid Background="#78131D28"
              Visibility="{Binding IsEditorOpen, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Border Width="316"
                    Padding="16"
                    Background="{StaticResource OrbitExpandedCardBrush}"
                    BorderBrush="{StaticResource OrbitExpandedBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="22"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">
                <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="720">
                    <StackPanel>
                        <TextBlock Text="{Binding EditorTitle}"
                                   FontSize="17"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource OrbitInkBrush}" />
                        <TextBlock Margin="0,6,0,14"
                                   Text="{Binding EditorSubtitle}"
                                   FontSize="11"
                                   Foreground="{StaticResource OrbitMutedBrush}"
                                   TextWrapping="Wrap" />

                        <Border Padding="12"
                                Margin="0,0,0,10"
                                Style="{StaticResource PanelCardStyle}"
                                Visibility="{Binding IsWeeklyTaskEditorOpen, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <StackPanel>
                                <TextBlock Text="项目名称" />
                                <ComboBox Margin="0,6,0,10"
                                          IsEditable="True"
                                          IsTextSearchEnabled="False"
                                          ItemsSource="{Binding WeeklyProjectNameOptions}"
                                          Text="{Binding WeeklyTaskForm.ProjectName, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBlock Text="任务标题" />
                                <TextBox Margin="0,6,0,10"
                                         Text="{Binding WeeklyTaskForm.Title, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBlock Text="任务状态" />
                                <ComboBox Margin="0,6,0,10"
                                          ItemsSource="{x:Static vm:StatusOptions.WeeklyTaskStatuses}"
                                          SelectedItem="{Binding WeeklyTaskForm.Status}">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Converter={StaticResource EnumDisplayConverter}}" />
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>
                                <TextBlock Text="备注" />
                                <TextBox Margin="0,6,0,10"
                                         Height="70"
                                         AcceptsReturn="True"
                                         TextWrapping="Wrap"
                                         VerticalScrollBarVisibility="Auto"
                                         Text="{Binding WeeklyTaskForm.Notes, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBlock Text="进度 (%)" />
                                <TextBox Margin="0,6,0,0"
                                         Text="{Binding WeeklyTaskForm.Progress, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                        </Border>

                        <Border Padding="12"
                                Margin="0,0,0,10"
                                Style="{StaticResource PanelCardStyle}"
                                Visibility="{Binding IsLongTermTaskEditorOpen, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <StackPanel>
                                <TextBlock Text="项目名称" />
                                <ComboBox Margin="0,6,0,10"
                                          IsEditable="True"
                                          IsTextSearchEnabled="False"
                                          ItemsSource="{Binding LongTermProjectNameOptions}"
                                          Text="{Binding LongTermTaskForm.ProjectName, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBlock Text="任务标题" />
                                <TextBox Margin="0,6,0,10"
                                         Text="{Binding LongTermTaskForm.Title, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBlock Text="任务状态" />
                                <ComboBox Margin="0,6,0,10"
                                          ItemsSource="{x:Static vm:StatusOptions.LongTermTaskStatuses}"
                                          SelectedItem="{Binding LongTermTaskForm.Status}">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Converter={StaticResource EnumDisplayConverter}}" />
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>
                                <TextBlock Text="开始时间" />
                                <DatePicker Margin="0,6,0,10"
                                            SelectedDate="{Binding LongTermTaskForm.StartDate}" />
                                <TextBlock Text="结束时间" />
                                <DatePicker Margin="0,6,0,10"
                                            SelectedDate="{Binding LongTermTaskForm.EndDate}" />
                                <TextBlock Text="备注" />
                                <TextBox Margin="0,6,0,10"
                                         Height="70"
                                         AcceptsReturn="True"
                                         TextWrapping="Wrap"
                                         VerticalScrollBarVisibility="Auto"
                                         Text="{Binding LongTermTaskForm.Notes, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBlock Text="进度 (%)" />
                                <TextBox Margin="0,6,0,0"
                                         Text="{Binding LongTermTaskForm.Progress, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                        </Border>

                        <Border Padding="12"
                                Margin="0,0,0,10"
                                Style="{StaticResource PanelCardStyle}"
                                 Visibility="{Binding IsSettingsOpen, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <StackPanel>
                                <TextBlock Text="系统"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource OrbitInkBrush}" />
                                <Border Padding="10"
                                        Margin="0,8,0,14"
                                        Background="{StaticResource OrbitTaskBrush}"
                                        BorderBrush="{StaticResource OrbitCardBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="14">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" Margin="0,0,12,0">
                                            <TextBlock Text="开机自动启动"
                                                       FontWeight="SemiBold"
                                                       Foreground="{StaticResource OrbitInkBrush}" />
                                            <TextBlock Margin="0,4,0,0"
                                                       Text="登录 Windows 后自动启动，并保持右侧触发条状态。"
                                                       FontSize="10"
                                                       Foreground="{StaticResource OrbitMutedBrush}"
                                                       TextWrapping="Wrap" />
                                        </StackPanel>
                                        <ToggleButton Grid.Column="1"
                                                      VerticalAlignment="Center"
                                                      Style="{StaticResource PinToggleButtonStyle}"
                                                      Content="{Binding StartWithWindowsText}"
                                                      IsChecked="{Binding StartWithWindows, Mode=OneWay}"
                                                      Click="StartWithWindowsButton_OnClick" />
                                    </Grid>
                                </Border>

                                <TextBlock Text="项目列表" />
                                <TextBlock Margin="0,6,0,10"
                                           Text="新增和修改后，项目会立即出现在新建任务的下拉框中。下拉框仍支持手动输入。"
                                           FontSize="10"
                                           Foreground="{StaticResource OrbitMutedBrush}"
                                           TextWrapping="Wrap" />

                                <Border Padding="10"
                                        Margin="0,0,0,10"
                                        Background="{StaticResource OrbitTaskBrush}"
                                        BorderBrush="{StaticResource OrbitCardBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="14">
                                    <ItemsControl ItemsSource="{Binding ProjectCatalogRows}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Grid Margin="0,0,0,8">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel Grid.Column="0" Margin="0,0,10,0">
                                                        <TextBlock Text="{Binding Name}"
                                                                   FontWeight="SemiBold"
                                                                   Foreground="{StaticResource OrbitInkBrush}" />
                                                        <TextBlock Margin="0,4,0,0"
                                                                   Text="{Binding Summary}"
                                                                   FontSize="10"
                                                                   Foreground="{StaticResource OrbitMutedBrush}" />
                                                    </StackPanel>
                                                    <WrapPanel Grid.Column="1">
                                                        <Button Style="{StaticResource MiniButtonStyle}"
                                                                Content="修改"
                                                                Tag="{Binding Id}"
                                                                Click="EditProjectCatalogButton_OnClick" />
                                                        <Button Margin="4,0,0,0"
                                                                Style="{StaticResource MiniButtonStyle}"
                                                                Content="删除"
                                                                Tag="{Binding Id}"
                                                                Click="DeleteProjectCatalogButton_OnClick" />
                                                    </WrapPanel>
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </Border>

                                <TextBlock Text="项目名称" />
                                <TextBox Margin="0,6,0,10"
                                         Text="{Binding SettingsForm.ProjectNameInput, UpdateSourceTrigger=PropertyChanged}" />

                                <WrapPanel>
                                    <Button Style="{StaticResource PrimaryActionButtonStyle}"
                                            Content="{Binding SettingsProjectActionText}"
                                            Click="SaveProjectCatalogButton_OnClick" />
                                    <Button Margin="6,0,0,0"
                                            Style="{StaticResource ActionButtonStyle}"
                                            Content="取消修改"
                                            Visibility="{Binding IsEditingProjectInSettings, Converter={StaticResource BooleanToVisibilityConverter}}"
                                            Click="CancelProjectCatalogEditButton_OnClick" />
                                </WrapPanel>
                            </StackPanel>
                        </Border>

                        <Border Padding="12"
                                Margin="0,0,0,10"
                                Style="{StaticResource PanelCardStyle}"
                                Visibility="{Binding IsAnnotationEditorOpen, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <StackPanel>
                                <TextBlock Text="批注记录"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource OrbitInkBrush}" />
                                <TextBlock Margin="0,4,0,10"
                                           Text="最新批注显示在任务卡片中；这里可以追加、修改和删除全部批注。"
                                           FontSize="10"
                                           Foreground="{StaticResource OrbitMutedBrush}"
                                           TextWrapping="Wrap" />

                                <Border Padding="10"
                                        Margin="0,0,0,10"
                                        Background="{StaticResource OrbitStatusBrush}"
                                        CornerRadius="12"
                                        Visibility="{Binding ShowAnnotationEmptyState, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <TextBlock Text="暂无批注，可以从下方添加第一条。"
                                               FontSize="10"
                                               Foreground="{StaticResource OrbitMutedBrush}" />
                                </Border>

                                <ItemsControl ItemsSource="{Binding AnnotationRows}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Padding="10"
                                                    Margin="0,0,0,8"
                                                    Background="{StaticResource OrbitTaskBrush}"
                                                    BorderBrush="{StaticResource OrbitCardBorderBrush}"
                                                    BorderThickness="1"
                                                    CornerRadius="12">
                                                <StackPanel>
                                                    <TextBlock Text="{Binding Content}"
                                                               FontSize="10.5"
                                                               Foreground="{StaticResource OrbitStatusInkBrush}"
                                                               TextWrapping="Wrap" />
                                                    <Grid Margin="0,7,0,0">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="Auto" />
                                                        </Grid.ColumnDefinitions>
                                                        <WrapPanel>
                                                            <TextBlock Text="{Binding TimeText}"
                                                                       FontSize="9"
                                                                       Foreground="{StaticResource OrbitMutedBrush}" />
                                                            <TextBlock Margin="6,0,0,0"
                                                                       Text="{Binding EditMarker}"
                                                                       FontSize="9"
                                                                       Foreground="{StaticResource OrbitMutedBrush}" />
                                                        </WrapPanel>
                                                        <WrapPanel Grid.Column="1">
                                                            <Button Style="{StaticResource MiniButtonStyle}"
                                                                    Content="修改"
                                                                    Tag="{Binding Id}"
                                                                    Click="EditAnnotationButton_OnClick" />
                                                            <Button Margin="4,0,0,0"
                                                                    Style="{StaticResource MiniButtonStyle}"
                                                                    Content="删除"
                                                                    Tag="{Binding Id}"
                                                                    Click="RequestDeleteAnnotationButton_OnClick" />
                                                        </WrapPanel>
                                                    </Grid>
                                                    <Border Margin="0,8,0,0"
                                                            Padding="8"
                                                            Background="#FFF3F1"
                                                            CornerRadius="8"
                                                            Visibility="{Binding IsDeletePending, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*" />
                                                                <ColumnDefinition Width="Auto" />
                                                            </Grid.ColumnDefinitions>
                                                            <TextBlock VerticalAlignment="Center"
                                                                       Text="确认删除这条批注？"
                                                                       FontSize="9.5"
                                                                       Foreground="#9B3A32" />
                                                            <WrapPanel Grid.Column="1">
                                                                <Button Style="{StaticResource MiniButtonStyle}"
                                                                        Content="确认删除"
                                                                        Tag="{Binding Id}"
                                                                        Click="ConfirmDeleteAnnotationButton_OnClick" />
                                                                <Button Margin="4,0,0,0"
                                                                        Style="{StaticResource MiniButtonStyle}"
                                                                        Content="取消"
                                                                        Click="CancelDeleteAnnotationButton_OnClick" />
                                                            </WrapPanel>
                                                        </Grid>
                                                    </Border>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <TextBlock Margin="0,4,0,0" Text="批注内容" />
                                <TextBox Margin="0,6,0,10"
                                         Height="78"
                                         AcceptsReturn="True"
                                         TextWrapping="Wrap"
                                         VerticalScrollBarVisibility="Auto"
                                         Text="{Binding AnnotationEditor.Content, UpdateSourceTrigger=PropertyChanged}" />
                                <WrapPanel>
                                    <Button Style="{StaticResource PrimaryActionButtonStyle}"
                                            Content="{Binding AnnotationSaveButtonText}"
                                            Click="SaveAnnotationButton_OnClick" />
                                    <Button Margin="6,0,0,0"
                                            Style="{StaticResource ActionButtonStyle}"
                                            Content="取消修改"
                                            Click="CancelAnnotationEditButton_OnClick" />
                                    <Button Margin="6,0,0,0"
                                            Style="{StaticResource ActionButtonStyle}"
                                            Content="关闭"
                                            Click="CancelEditorButton_OnClick" />
                                </WrapPanel>
                            </StackPanel>
                        </Border>

                        <TextBlock Margin="0,0,0,12"
                                   Text="{Binding EditorValidationMessage}"
                                   Foreground="#B22D2D"
                                   TextWrapping="Wrap"
                                   Visibility="{Binding HasEditorValidationMessage, Converter={StaticResource BooleanToVisibilityConverter}}" />

                        <Grid Visibility="{Binding ShowGenericEditorFooter, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Button Grid.Column="0"
                                    Margin="0,0,8,0"
                                    Style="{StaticResource ActionButtonStyle}"
                                    Content="取消"
                                    Visibility="{Binding ShowDualFooterButtons, Converter={StaticResource BooleanToVisibilityConverter}}"
                                    Click="CancelEditorButton_OnClick" />
                            <Button Grid.Column="1"
                                    Margin="8,0,0,0"
                                    Style="{StaticResource PrimaryActionButtonStyle}"
                                    Content="{Binding EditorConfirmButtonText}"
                                    Click="SaveEditorButton_OnClick" />
                        </Grid>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>
    </Grid>
</Window>

<Window x:Class="Horizon.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:Horizon.App.ViewModels"
        xmlns:conv="clr-namespace:Horizon.App.Converters"
        mc:Ignorable="d"
        Title="Horizon"
        Width="338"
        Height="900"
        FontFamily="Microsoft YaHei UI"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="True"
        Loaded="MainWindow_OnLoaded"
        MouseEnter="MainWindow_OnMouseEnter"
        MouseLeave="MainWindow_OnMouseLeave"
        LocationChanged="MainWindow_OnLocationOrSizeChanged"
        SizeChanged="MainWindow_OnLocationOrSizeChanged"
        PreviewKeyDown="MainWindow_OnPreviewKeyDown">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <conv:EnumDisplayConverter x:Key="EnumDisplayConverter" />

        <Style TargetType="Button">
            <Setter Property="Foreground" Value="#18324A" />
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="BorderBrush" Value="#D7DFE8" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="10,6" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontSize" Value="11.5" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonChrome"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="14">
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonChrome" Property="Opacity" Value="0.9" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonChrome" Property="Opacity" Value="0.78" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ButtonChrome" Property="Opacity" Value="0.4" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ActionButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="#F7F9FC" />
            <Setter Property="BorderBrush" Value="#D9E2EC" />
            <Setter Property="Foreground" Value="#17324A" />
        </Style>

        <Style x:Key="PrimaryActionButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="#173B63" />
            <Setter Property="BorderBrush" Value="#173B63" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Padding" Value="12,6" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style x:Key="MiniButtonStyle" TargetType="Button" BasedOn="{StaticResource ActionButtonStyle}">
            <Setter Property="Padding" Value="8,4" />
            <Setter Property="FontSize" Value="10.5" />
        </Style>

        <Style x:Key="LinkButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Foreground" Value="#215FA8" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style x:Key="SegmentRadioButtonStyle" TargetType="RadioButton">
            <Setter Property="Foreground" Value="#738396" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="FontSize" Value="10" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Chip"
                                Margin="2"
                                Padding="8,5"
                                Background="Transparent"
                                CornerRadius="999">
                            <TextBlock Text="{TemplateBinding Content}"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       FontSize="{TemplateBinding FontSize}"
                                       Foreground="{TemplateBinding Foreground}"
                                       FontWeight="Medium" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Chip" Property="Background" Value="#FFFFFF" />
                                <Setter TargetName="Chip" Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect BlurRadius="8"
                                                          ShadowDepth="0"
                                                          Opacity="0.09"
                                                          Color="#18324A" />
                                    </Setter.Value>
                                </Setter>
                                <Setter Property="Foreground" Value="#173B63" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Padding" Value="7,4" />
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="BorderBrush" Value="#D9E1EA" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="#18324A" />
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Padding" Value="9,7" />
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="BorderBrush" Value="#D9E1EA" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="#18324A" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PanelCardStyle" TargetType="Border">
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="BorderBrush" Value="#E1E6ED" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="18" />
        </Style>

        <DataTemplate x:Key="WeeklyProjectSectionTemplate" DataType="{x:Type vm:ProjectSectionViewModel}">
            <Border Margin="0,0,0,10"
                    Padding="12"
                    Style="{StaticResource PanelCardStyle}">
                <StackPanel>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Margin="0,0,10,0">
                            <TextBlock Text="{Binding ProjectName}"
                                       FontSize="13.5"
                                       FontWeight="SemiBold"
                                       Foreground="#10263C" />
                            <TextBlock Margin="0,4,0,0"
                                       Text="{Binding ProjectMeta}"
                                       FontSize="10"
                                       Foreground="#6B7B8C" />
                        </StackPanel>

                        <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                            <Border Padding="8,4"
                                    HorizontalAlignment="Right"
                                    Background="{Binding StatusBadgeBackground}"
                                    CornerRadius="999">
                                <TextBlock Text="{Binding StatusText}"
                                           FontSize="10"
                                           FontWeight="SemiBold"
                                           Foreground="{Binding StatusBadgeForeground}" />
                            </Border>
                            <WrapPanel Margin="0,8,0,0" HorizontalAlignment="Right">
                                <Button Style="{StaticResource MiniButtonStyle}"
                                        Content="编辑"
                                        Tag="{Binding ProjectId}"
                                        Click="EditProjectButton_OnClick" />
                                <Button Margin="6,0,0,0"
                                        Style="{StaticResource MiniButtonStyle}"
                                        Content="{Binding ArchiveActionText}"
                                        Tag="{Binding ProjectId}"
                                        Click="ToggleProjectArchiveButton_OnClick" />
                            </WrapPanel>
                        </StackPanel>
                    </Grid>

                    <ItemsControl Margin="0,10,0,0"
                                  ItemsSource="{Binding WeeklyTasks}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,0,0,8"
                                        Padding="10"
                                        Background="#F7F9FC"
                                        BorderBrush="#E5EBF2"
                                        BorderThickness="1"
                                        CornerRadius="14">
                                    <StackPanel>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>

                                            <StackPanel Grid.Column="0" Margin="0,0,10,0">
                                                <TextBlock Text="{Binding Title}"
                                                           FontSize="12"
                                                           FontWeight="SemiBold"
                                                           TextWrapping="Wrap"
                                                           Foreground="#17324A" />
                                                <TextBlock Margin="0,5,0,0"
                                                           Text="{Binding MetaText}"
                                                           FontSize="10"
                                                           Foreground="#6A7A8A"
                                                           Visibility="{Binding HasMetaText, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                            </StackPanel>

                                            <Button Grid.Column="1"
                                                    Style="{StaticResource MiniButtonStyle}"
                                                    Content="编辑"
                                                    Tag="{Binding Id}"
                                                    Click="EditWeeklyTaskButton_OnClick" />
                                        </Grid>

                                        <Border Margin="0,8,0,0"
                                                Padding="9,7"
                                                Background="#FFFFFF"
                                                BorderBrush="#E5EBF2"
                                                BorderThickness="1"
                                                CornerRadius="12"
                                                Visibility="{Binding HasNotesPreview, Converter={StaticResource BooleanToVisibilityConverter}}">
                                            <TextBlock Text="{Binding NotesPreview}"
                                                       FontSize="10"
                                                       Foreground="#324A61"
                                                       TextWrapping="Wrap" />
                                        </Border>

                                        <Border Margin="0,10,0,0"
                                                Padding="2"
                                                Background="#EEF2F6"
                                                BorderBrush="#E1E7EE"
                                                BorderThickness="1"
                                                CornerRadius="999">
                                            <UniformGrid Columns="3">
                                                <RadioButton Style="{StaticResource SegmentRadioButtonStyle}"
                                                             GroupName="{Binding StatusGroupName}"
                                                             Content="未开始"
                                                             Tag="{Binding Id}"
                                                             IsChecked="{Binding IsTodo, Mode=OneWay}"
                                                             Checked="WeeklyTodoButton_OnChecked" />
                                                <RadioButton Style="{StaticResource SegmentRadioButtonStyle}"
                                                             GroupName="{Binding StatusGroupName}"
                                                             Content="进行中"
                                                             Tag="{Binding Id}"
                                                             IsChecked="{Binding IsInProgress, Mode=OneWay}"
                                                             Checked="WeeklyInProgressButton_OnChecked" />
                                                <RadioButton Style="{StaticResource SegmentRadioButtonStyle}"
                                                             GroupName="{Binding StatusGroupName}"
                                                             Content="已完成"
                                                             Tag="{Binding Id}"
                                                             IsChecked="{Binding IsDone, Mode=OneWay}"
                                                             Checked="WeeklyDoneButton_OnChecked" />
                                            </UniformGrid>
                                        </Border>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <Button Margin="0,2,0,0"
                            HorizontalAlignment="Left"
                            Style="{StaticResource LinkButtonStyle}"
                            Content="+ 添加本周任务"
                            Tag="{Binding ProjectId}"
                            Click="AddWeeklyTaskForProjectButton_OnClick" />
                </StackPanel>
            </Border>
        </DataTemplate>

        <DataTemplate x:Key="LongTermProjectSectionTemplate" DataType="{x:Type vm:ProjectSectionViewModel}">
            <Border Margin="0,0,0,10"
                    Padding="12"
                    Style="{StaticResource PanelCardStyle}">
                <StackPanel>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Margin="0,0,10,0">
                            <TextBlock Text="{Binding ProjectName}"
                                       FontSize="13.5"
                                       FontWeight="SemiBold"
                                       Foreground="#10263C" />
                            <TextBlock Margin="0,4,0,0"
                                       Text="{Binding ProjectMeta}"
                                       FontSize="10"
                                       Foreground="#6B7B8C" />
                        </StackPanel>

                        <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                            <Border Padding="8,4"
                                    HorizontalAlignment="Right"
                                    Background="{Binding StatusBadgeBackground}"
                                    CornerRadius="999">
                                <TextBlock Text="{Binding StatusText}"
                                           FontSize="10"
                                           FontWeight="SemiBold"
                                           Foreground="{Binding StatusBadgeForeground}" />
                            </Border>
                            <WrapPanel Margin="0,8,0,0" HorizontalAlignment="Right">
                                <Button Style="{StaticResource MiniButtonStyle}"
                                        Content="编辑"
                                        Tag="{Binding ProjectId}"
                                        Click="EditProjectButton_OnClick" />
                                <Button Margin="6,0,0,0"
                                        Style="{StaticResource MiniButtonStyle}"
                                        Content="{Binding ArchiveActionText}"
                                        Tag="{Binding ProjectId}"
                                        Click="ToggleProjectArchiveButton_OnClick" />
                            </WrapPanel>
                        </StackPanel>
                    </Grid>

                    <ItemsControl Margin="0,10,0,0"
                                  ItemsSource="{Binding LongTermTasks}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,0,0,8"
                                        Padding="10"
                                        Background="#F7F9FC"
                                        BorderBrush="#E5EBF2"
                                        BorderThickness="1"
                                        CornerRadius="14">
                                    <StackPanel>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>

                                            <StackPanel Grid.Column="0" Margin="0,0,10,0">
                                                <TextBlock Text="{Binding Title}"
                                                           FontSize="12"
                                                           FontWeight="SemiBold"
                                                           TextWrapping="Wrap"
                                                           Foreground="#17324A" />
                                                <TextBlock Margin="0,5,0,0"
                                                           Text="{Binding MetaText}"
                                                           FontSize="10"
                                                           Foreground="#6A7A8A"
                                                           Visibility="{Binding HasMetaText, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                            </StackPanel>

                                            <Button Grid.Column="1"
                                                    Style="{StaticResource MiniButtonStyle}"
                                                    Content="编辑"
                                                    Tag="{Binding Id}"
                                                    Click="EditLongTermTaskButton_OnClick" />
                                        </Grid>

                                        <Border Margin="0,8,0,0"
                                                Padding="9,7"
                                                Background="#FFFFFF"
                                                BorderBrush="#E5EBF2"
                                                BorderThickness="1"
                                                CornerRadius="12"
                                                Visibility="{Binding HasNotesPreview, Converter={StaticResource BooleanToVisibilityConverter}}">
                                            <TextBlock Text="{Binding NotesPreview}"
                                                       FontSize="10"
                                                       Foreground="#324A61"
                                                       TextWrapping="Wrap" />
                                        </Border>

                                        <Border Margin="0,10,0,0"
                                                Padding="2"
                                                Background="#EEF2F6"
                                                BorderBrush="#E1E7EE"
                                                BorderThickness="1"
                                                CornerRadius="999">
                                            <UniformGrid Columns="3">
                                                <RadioButton Style="{StaticResource SegmentRadioButtonStyle}"
                                                             GroupName="{Binding StatusGroupName}"
                                                             Content="未开始"
                                                             Tag="{Binding Id}"
                                                             IsChecked="{Binding IsPlanned, Mode=OneWay}"
                                                             Checked="LongTermPlannedButton_OnChecked" />
                                                <RadioButton Style="{StaticResource SegmentRadioButtonStyle}"
                                                             GroupName="{Binding StatusGroupName}"
                                                             Content="进行中"
                                                             Tag="{Binding Id}"
                                                             IsChecked="{Binding IsActive, Mode=OneWay}"
                                                             Checked="LongTermActiveButton_OnChecked" />
                                                <RadioButton Style="{StaticResource SegmentRadioButtonStyle}"
                                                             GroupName="{Binding StatusGroupName}"
                                                             Content="已完成"
                                                             Tag="{Binding Id}"
                                                             IsChecked="{Binding IsCompleted, Mode=OneWay}"
                                                             Checked="LongTermCompletedButton_OnChecked" />
                                            </UniformGrid>
                                        </Border>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <Button Margin="0,2,0,0"
                            HorizontalAlignment="Left"
                            Style="{StaticResource LinkButtonStyle}"
                            Content="+ 添加长期任务"
                            Tag="{Binding ProjectId}"
                            Click="AddLongTermTaskForProjectButton_OnClick" />
                </StackPanel>
            </Border>
        </DataTemplate>
    </Window.Resources>

    <Grid>
        <Border x:Name="ExpandedPanelShell"
                Margin="6"
                Background="#F4F6F8"
                BorderBrush="#D8E0E8"
                BorderThickness="1"
                CornerRadius="28">
            <Grid Margin="12">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                        <TextBlock Text="Horizon"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   Foreground="#0F2438" />
                        <TextBlock Margin="0,3,0,0"
                                   Text="{Binding HeaderSubtitle}"
                                   FontSize="10"
                                   Foreground="#708092" />
                    </StackPanel>

                    <WrapPanel Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <Button x:Name="QuickAddButton"
                                Margin="0,0,6,0"
                                Style="{StaticResource PrimaryActionButtonStyle}"
                                Content="新增内容"
                                Click="QuickAddButton_OnClick" />
                        <Button Margin="0,0,6,0"
                                Style="{StaticResource ActionButtonStyle}"
                                Content="{Binding ArchiveToggleText}"
                                Click="ArchiveToggleButton_OnClick" />
                        <Button Style="{StaticResource ActionButtonStyle}"
                                Content="{Binding HistoryToggleText}"
                                Click="HistoryToggleButton_OnClick" />
                    </WrapPanel>
                </Grid>

                <Border Grid.Row="1"
                        Margin="0,0,0,10"
                        Padding="10,8"
                        Background="#EDF4FB"
                        BorderBrush="#D9E6F3"
                        BorderThickness="1"
                        CornerRadius="14"
                        Visibility="{Binding HasStatusMessage, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <TextBlock Text="{Binding StatusMessage}"
                               FontSize="10"
                               Foreground="#40627F" />
                </Border>

                <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <Border Padding="16"
                                Margin="0,0,0,10"
                                Style="{StaticResource PanelCardStyle}"
                                Visibility="{Binding ShowProjectFirstEmptyState, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <StackPanel>
                                <TextBlock Text="还没有项目"
                                           FontSize="15"
                                           FontWeight="SemiBold"
                                           Foreground="#10263C" />
                                <TextBlock Margin="0,6,0,12"
                                           Text="先建立项目，再把本周任务和长期任务挂进去。"
                                           FontSize="11"
                                           Foreground="#6B7B8C"
                                           TextWrapping="Wrap" />
                                <Button HorizontalAlignment="Left"
                                        Style="{StaticResource PrimaryActionButtonStyle}"
                                        Content="新建第一个项目"
                                        Click="CreateProjectButton_OnClick" />
                            </StackPanel>
                        </Border>

                        <StackPanel Visibility="{Binding IsCurrentWeeklyView, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <TextBlock Text="本周任务"
                                       FontSize="14.5"
                                       FontWeight="SemiBold"
                                       Foreground="#10263C" />
                            <TextBlock Margin="0,4,0,10"
                                       Text="鼠标移入展开，移出后会平滑收回右下角。"
                                       FontSize="10.5"
                                       Foreground="#6B7B8C" />

                            <Border Padding="14"
                                    Margin="0,0,0,10"
                                    Style="{StaticResource PanelCardStyle}"
                                    Visibility="{Binding ShowWeeklyEmptyState, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <StackPanel>
                                    <TextBlock Text="本周还没有任务"
                                               FontWeight="SemiBold"
                                               Foreground="#10263C" />
                                    <TextBlock Margin="0,6,0,12"
                                               Text="只放最重要的几件事，面板会更清晰。"
                                               FontSize="10.5"
                                               Foreground="#6B7B8C"
                                               TextWrapping="Wrap" />
                                    <Button HorizontalAlignment="Left"
                                            Style="{StaticResource PrimaryActionButtonStyle}"
                                            Content="新增本周任务"
                                            Click="CreateWeeklyTaskButton_OnClick" />
                                </StackPanel>
                            </Border>

                            <ItemsControl ItemsSource="{Binding WeeklySections}"
                                          ItemTemplate="{StaticResource WeeklyProjectSectionTemplate}" />

                            <TextBlock Margin="0,6,0,0"
                                       Text="长期任务"
                                       FontSize="14.5"
                                       FontWeight="SemiBold"
                                       Foreground="#10263C" />
                            <TextBlock Margin="0,4,0,10"
                                       Text="长期任务按项目归类，保留开始和结束时间。"
                                       FontSize="10.5"
                                       Foreground="#6B7B8C" />

                            <Border Padding="14"
                                    Margin="0,0,0,10"
                                    Style="{StaticResource PanelCardStyle}"
                                    Visibility="{Binding ShowLongTermEmptyState, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <StackPanel>
                                    <TextBlock Text="还没有长期任务"
                                               FontWeight="SemiBold"
                                               Foreground="#10263C" />
                                    <TextBlock Margin="0,6,0,12"
                                               Text="长期任务会固定在项目下，方便持续推进。"
                                               FontSize="10.5"
                                               Foreground="#6B7B8C"
                                               TextWrapping="Wrap" />
                                    <Button HorizontalAlignment="Left"
                                            Style="{StaticResource ActionButtonStyle}"
                                            Content="新增长期任务"
                                            Click="CreateLongTermTaskButton_OnClick" />
                                </StackPanel>
                            </Border>

                            <ItemsControl ItemsSource="{Binding LongTermSections}"
                                          ItemTemplate="{StaticResource LongTermProjectSectionTemplate}" />
                        </StackPanel>

                        <StackPanel Visibility="{Binding ShowWeeklyHistory, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <TextBlock Text="往期周任务"
                                       FontSize="14.5"
                                       FontWeight="SemiBold"
                                       Foreground="#10263C" />
                            <TextBlock Margin="0,4,0,10"
                                       Text="按周回看之前的任务记录。"
                                       FontSize="10.5"
                                       Foreground="#6B7B8C" />

                            <Border Padding="14"
                                    Margin="0,0,0,10"
                                    Style="{StaticResource PanelCardStyle}"
                                    Visibility="{Binding ShowWeeklyHistoryEmptyState, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <TextBlock Text="当前还没有可查看的往期周任务。"
                                           FontSize="10.5"
                                           Foreground="#6B7B8C" />
                            </Border>

                            <ItemsControl ItemsSource="{Binding WeeklyHistoryGroups}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="0,0,0,10"
                                                Padding="12"
                                                Style="{StaticResource PanelCardStyle}">
                                            <StackPanel>
                                                <TextBlock Text="{Binding WeekTitle}"
                                                           FontSize="13"
                                                           FontWeight="SemiBold"
                                                           Foreground="#10263C" />
                                                <TextBlock Margin="0,4,0,10"
                                                           Text="{Binding WeekSubtitle}"
                                                           FontSize="10"
                                                           Foreground="#6B7B8C" />
                                                <ItemsControl ItemsSource="{Binding Sections}"
                                                              ItemTemplate="{StaticResource WeeklyProjectSectionTemplate}" />
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Border>

        <Border x:Name="CollapsedSensorShell"
                Width="22"
                Background="#173B63"
                CornerRadius="11"
                Visibility="Collapsed">
            <Grid>
                <Border Width="6"
                        Height="34"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Background="#F1F6FC"
                        CornerRadius="3" />
            </Grid>
        </Border>

        <Grid Background="#78131D28"
              Visibility="{Binding IsEditorOpen, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Border Width="300"
                    Padding="16"
                    Background="#FFFFFF"
                    BorderBrush="#D9E1EA"
                    BorderThickness="1"
                    CornerRadius="24"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">
                <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="680">
                    <StackPanel>
                        <TextBlock Text="{Binding EditorTitle}"
                                   FontSize="17"
                                   FontWeight="SemiBold"
                                   Foreground="#10263C" />
                        <TextBlock Margin="0,6,0,14"
                                   Text="{Binding EditorSubtitle}"
                                   FontSize="11"
                                   Foreground="#6B7B8C"
                                   TextWrapping="Wrap" />

                        <Border Padding="12"
                                Margin="0,0,0,10"
                                Style="{StaticResource PanelCardStyle}"
                                Visibility="{Binding IsProjectEditorOpen, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <StackPanel>
                                <TextBlock Text="项目名称" />
                                <TextBox Margin="0,6,0,10"
                                         Text="{Binding ProjectForm.Name, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBlock Text="项目状态" />
                                <ComboBox Margin="0,6,0,0"
                                          ItemsSource="{x:Static vm:StatusOptions.ProjectStatuses}"
                                          SelectedItem="{Binding ProjectForm.Status}">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Converter={StaticResource EnumDisplayConverter}}" />
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>
                            </StackPanel>
                        </Border>

                        <Border Padding="12"
                                Margin="0,0,0,10"
                                Style="{StaticResource PanelCardStyle}"
                                Visibility="{Binding IsWeeklyTaskEditorOpen, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <StackPanel>
                                <TextBlock Text="所属项目" />
                                <ComboBox Margin="0,6,0,10"
                                          ItemsSource="{Binding ActiveProjectOptions}"
                                          DisplayMemberPath="Name"
                                          SelectedValuePath="Id"
                                          SelectedValue="{Binding WeeklyTaskForm.ProjectId}" />
                                <TextBlock Text="任务标题" />
                                <TextBox Margin="0,6,0,10"
                                         Text="{Binding WeeklyTaskForm.Title, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBlock Text="任务状态" />
                                <ComboBox Margin="0,6,0,10"
                                          ItemsSource="{x:Static vm:StatusOptions.WeeklyTaskStatuses}"
                                          SelectedItem="{Binding WeeklyTaskForm.Status}">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Converter={StaticResource EnumDisplayConverter}}" />
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>
                                <TextBlock Text="周起始日期" />
                                <DatePicker Margin="0,6,0,10"
                                            SelectedDate="{Binding WeeklyTaskForm.WeekStartDate}" />
                                <TextBlock Text="截止日期（可选）" />
                                <DatePicker Margin="0,6,0,10"
                                            SelectedDate="{Binding WeeklyTaskForm.DueDate}" />
                                <TextBlock Text="备注" />
                                <TextBox Margin="0,6,0,0"
                                         Height="70"
                                         AcceptsReturn="True"
                                         TextWrapping="Wrap"
                                         VerticalScrollBarVisibility="Auto"
                                         Text="{Binding WeeklyTaskForm.Notes, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                        </Border>

                        <Border Padding="12"
                                Margin="0,0,0,10"
                                Style="{StaticResource PanelCardStyle}"
                                Visibility="{Binding IsLongTermTaskEditorOpen, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <StackPanel>
                                <TextBlock Text="所属项目" />
                                <ComboBox Margin="0,6,0,10"
                                          ItemsSource="{Binding ActiveProjectOptions}"
                                          DisplayMemberPath="Name"
                                          SelectedValuePath="Id"
                                          SelectedValue="{Binding LongTermTaskForm.ProjectId}" />
                                <TextBlock Text="任务标题" />
                                <TextBox Margin="0,6,0,10"
                                         Text="{Binding LongTermTaskForm.Title, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBlock Text="任务状态" />
                                <ComboBox Margin="0,6,0,10"
                                          ItemsSource="{x:Static vm:StatusOptions.LongTermTaskStatuses}"
                                          SelectedItem="{Binding LongTermTaskForm.Status}">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Converter={StaticResource EnumDisplayConverter}}" />
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>
                                <TextBlock Text="开始日期" />
                                <DatePicker Margin="0,6,0,10"
                                            SelectedDate="{Binding LongTermTaskForm.StartDate}" />
                                <TextBlock Text="结束日期" />
                                <DatePicker Margin="0,6,0,10"
                                            SelectedDate="{Binding LongTermTaskForm.EndDate}" />
                                <TextBlock Text="备注" />
                                <TextBox Margin="0,6,0,0"
                                         Height="70"
                                         AcceptsReturn="True"
                                         TextWrapping="Wrap"
                                         VerticalScrollBarVisibility="Auto"
                                         Text="{Binding LongTermTaskForm.Notes, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                        </Border>

                        <TextBlock Margin="0,0,0,12"
                                   Text="{Binding EditorValidationMessage}"
                                   Foreground="#B22D2D"
                                   TextWrapping="Wrap"
                                   Visibility="{Binding HasEditorValidationMessage, Converter={StaticResource BooleanToVisibilityConverter}}" />

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Button Grid.Column="0"
                                    Margin="0,0,8,0"
                                    Style="{StaticResource ActionButtonStyle}"
                                    Content="取消"
                                    Click="CancelEditorButton_OnClick" />
                            <Button Grid.Column="1"
                                    Margin="8,0,0,0"
                                    Style="{StaticResource PrimaryActionButtonStyle}"
                                    Content="保存"
                                    Click="SaveEditorButton_OnClick" />
                        </Grid>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>
    </Grid>
</Window>
